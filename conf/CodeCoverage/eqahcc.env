# =============================================================================
# Remote Debug Service Code Coverage options
# =============================================================================

# The directory to save the code coverage result files. Each user will have a
# subdirectory in the output directory with their code coverage results
#output=/var/debug


# NJL- Enabled - disable - hard to get perm righ - default to ccs's own defaut home above /u/stgdbg 
#output=/u/ibmuser/tmp 

# added to allow headless startup to use =o parm to redirector output folder rpts
allowoutputlocation=TRUE


# The code coverage level (either "LINE" or "FUNCTION").
# The default is LINE
#cclevel=FUNCTION

# Specifies an optional file that contains a list modules used by MODULE level
# code coverage.
#modulelist=<path>

# Specifies an optional file that contains a list of regular expressions that
# will cause matching module names to be excluded from code coverage.
#moduleexludelist=<path>

# Comma separated list of module names or module expressions that will be
# included in code coverage. Module expressions can use '*' or '?' to match
# module names. Module include overrides the module exclude parameter.
#moduleinclude=<module_list>

# Specifies an optional file that contains a list of module names that should
# be included in code coverage. Module expressions can use '*' or '?' to match
# module names. Module include overrides the module exclude parameter.
#moduleincludelist=<path>

# Specifies a file that contains commands that will be sent to the debug engine
# at startup.
#startupcommandlist=<path>

# Saves the source with the results.
# The default is TRUE.
#savesource=FALSE

# Choose the view to use when you save source.
#      DEFAULT uses whatever is the engine preferred view.
#      SOURCE_LISTING uses the source view first. When the source view is not 
#                     found or is not available, it will default to the LISTING
#                     view. Not supported in Debug Tool compatibility mode.
#      SOURCE_ONLY only allows source views to be included in code coverage
#                  collection.
#      LISTING_ONLY only allows listing views to be included in code coverage
#                   collection.
#view=DEFAULT

# Number of seconds to wait for a debug engine response before timing out.
# The session will terminate and results already captured will be saved.
# Specifying 0 (zero) will wait indefinitely.
# The default is 120 seconds.     
#timeout=<seconds>
    
# Results will be produced even if errors occur during the session. 
# The results may be incomplete.
#ignoreerrors=TRUE

# Results will be associated with the specified testid.
#testid=<testid>

# Specifies a tag that will be associated with the CC results. e.g. test ID.
#tag="text"
    
# Specifies the export format for code coverage data. You can specify multiple
# export types by using a comma to separate.
#    exportertype=ccsonarqube produces the SonarQube format with the .xml extension.
#    exportertype=ccpdf produces the portable document format with the .pdf extension.
#exportertype=<exporter type>


# NJL- Enabled -disable  ad to startKey 
#exportertype=ccsonarqube 

# Start Code Coverage Service on the specified port. CCS will not start if the port is already in use.
#ccsport=8007

## NJL ADDED saw 8196 under  rseapi ???  chg to 197 
ccsport=8197



# APPLID used for generating the token for bearer authentication. Make sure that SAF JWT Authentication is configured for the specified APPLID
# If enablebasicauth is set to FALSE, you must provide an APPLID or CCS will not start.
#applid=FEKAPPL

# Enable basic authentication on Headless Code Coverage Service. Can be used together with Bearer Authentication.
enablebasicauth=FALSE