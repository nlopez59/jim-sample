# ====================================================================
# Remote Debug Service configurations
# ====================================================================


# --------------------------------------------------------------------
# Ports required to run the service:
#   'port_internal' must be specified
# And at least one of the following options must be specified:
#   'port_external_secure'
#   'allow_unsecured_remote_connections=true'
# --------------------------------------------------------------------

# Port number the service listens to for internal debug backend 
# connections from the local z/OS machine. This port is mandatory. 
# This port may be secured with AT-TLS if encryption of 
# localhost->localhost connections is desired.
port_internal="8193"

# Allow the internal port number to also listen for unsecured incoming
# requests from remote debug clients. Uncomment this line to enable 
# listening for unsecured remote connections on 'port_internal'.
#allow_unsecured_remote_connections="true"

# Port number the service listens to for incoming requests from remote
# debug clients. AT-TLS may be used to secure this port. This option 
# is mutually-exclusive with 'port_external_secure'
#port_external="8002"

# Port number the service listens to for secured incoming requests 
# from remote debug clients. This port is encrypted by Java. Do not 
# use AT-TLS to secure this port. This option is mutually-exclusive 
# with 'port_external'
port_external_secure="8194"


# --------------------------------------------------------------------
# TLS keystore and password:
#  'keystoreFile' and 'keystorePass' or 'keystorePassFile' must be 
#  specified if 'port_external_secured' is specified.
# --------------------------------------------------------------------

# The fully-qualified path name of the PKCS12 or JKS keystore file 
# where the Remote Debug Service TLS server certificate is stored. 
# This keystore can also contain self-signed or internal signing CA 
# certificates that should be trusted when the Remote Debug Service 
# makes authentication calls to the Debug Profile Service
# (see 'bearerAuth' and 'debugProfileServiceBaseURI')
keystoreFile=/etc/debug/keystore.p12

# Specify either 'keystorePass' or 'keystorePassFile'. Providing an 
# encrypted password in 'keystorePassFile' is recommended to prevent 
# storage in plaintext. If both options are specified, RDS will
# use the encrypted password defined inside the file specified by 
# 'keystorePassFile'.

# Password to access the server certificate from the keystore file
keystorePass="ibmuser"

# Pathname of the encrypted keystore password file generated using the 
# z/OS Debugger Password File Generator tool.
keystorePassFile=""


# --------------------------------------------------------------------
# Authentication
#
# At least one of the following must be enabled:
#
# (a) 'basicAuth':
#      Basic authentication uses a fixed userid + password.
#      BasicAuth credentials are validated directly with SAF.
#
# (b) 'bearerAuth':
#      Bearer/Token authentication uses a JWT token obtained and 
#      validated through the Debug Profile Service. Bearer/Token 
#      authentication is required for Multi-Factor Authentication.
#
#      If 'bearerAuth=true', then 'debugProfileServiceBaseURI' 
#      must be defined and point to a valid running instance of 
#      the Debug Profile Service.
# --------------------------------------------------------------------

# Allow users to connect using Basic authentication (userid+password)
basicAuth=true

# Allow users to connect using Bearer/Token authentication
# This mechanism is compatible with Multi-Factor Authentication (MFA)
#bearerAuth=true

# The base URL of the Debug Profile Service instance that will be used
# to validate tokens used when Bearer/Token authentication is enabled.
# If the Debug Profile Service is secured and uses self-signed 
# certificates or internal signing CAs, these certificates should be 
# placed in the keystore used by the Remote Debug Service to indicate 
# that they are trusted (see 'keystoreFile')
#debugProfileServiceBaseURI="https://localhost:8143/api/v1"


# --------------------------------------------------------------------
# Other server config paths and files:
# --------------------------------------------------------------------

# Home directory of the 64-bit Java SDK
java_dir="/usr/lpp/java/java17/current_64/"

# Working directory of the Remote Debug Service
# NOTE: this variable is no longer used and will be ignored. Remote 
# Debug Service working directories will automatically be written 
# under $EQARMTD_WRK_DIR
#eqarmtd_workdir="$EQARMTD_WRK_DIR/workspace"

# --------------------------------------------------------------------
# Diagnostic tracing of service and debug connections
# --------------------------------------------------------------------
#eqarmtd_logdir="$EQARMTD_WRK_DIR/logs"
#trace=true
#JAAS_LOGIN_MODULE_DEBUG=true
#detailedTraceOptions="$EQARMTD_CFG_DIR/trace.options"
#detailedTrace=true

# --------------------------------------------------------------------
# File permissions to be used when new files/directories are created
# --------------------------------------------------------------------
#umask="u+rwx,go=rx"

# NJL - CHGD above to 
umask="u+rwx,go=rwx"


# --------------------------------------------------------------------
# Headless Code coverage and Code Coverage Service options
# --------------------------------------------------------------------

#headless_cc=true
# NJL- Enabled
headless_cc=true


#headless_cc_config="$EQARMTD_CFG_DIR/eqahcc.env"
# NJL- Enabled all except blk ip
headless_cc_config="$EQARMTD_CFG_DIR/eqahcc.env"

ccs_maxRequestsPerSec=25
ccs_maxConcurRequests=20
#ccs_blockIPAccess=true

#  Begin Ansible Insert Block  #
OPENJ9_JAVA_OPTIONS="-Xms256m -Xmx512m -Xquickstart -Xscmx30m"
OPENJ9_JAVA_OPTIONS="$OPENJ9_JAVA_OPTIONS -Xshareclasses:nonFatal,cacheDirPerm=0777,cacheDir=/javasc/eqarmtd,name=eqarmtdcache"
OPENJ9_JAVA_OPTIONS="$OPENJ9_JAVA_OPTIONS -Xlp:objectheap:pagesize=1m,warn,pageable -Xlp:codecache:pagesize=1m,pageable"                     
#  End Ansible of Insert Block  #
