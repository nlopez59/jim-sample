---
# A sample Wazi Deploy (WD) environment descriptor file v17 (Feb 2026) 
# This files defines a target zOS host's environment setting for DB2 CICS and Batch deployment and target PDSs ..
#  
# Building blocks supported by this config: 
#   https://www.ibm.com/docs/en/developer-for-zos/17.0.x?topic=blocks-member-copy
#   https://www.ibm.com/docs/en/developer-for-zos/17.0.x?topic=blocks-db2-bind-package
#   https://www.ibm.com/docs/en/developer-for-zos/17.0.x?topic=blocks-cics-cmci-prog-update

apiVersion: deploy.ibm.com/v1
kind:       Environment

metadata:
  name:     "Dev1"
  version:  1.0.0
  description: "A sample environment definition file for a Dev Sandbox. Change the various setting to match your target z Host"


# Defaults 
hlq:        "ZDEV.WD"
uss_root:   "tmp/wd-root"
jobcard:    "IBMUSERK JOB WD,MSGLEVEL=(1,1),MSGCLASS=A,NOTIFY=&SYSUID" 
clave:      "jeep0924"


# vars passed via the "-e' cli option
#pklist:     "{{ extra_vars.app_pklist }}"
pklist:     "{{ app_pklist }}"


# the spec section defines section subsection like CICS and DB2 vars passed within the types: section to a building-block process

spec:
  default_cics_cmci_action: "NEWCOPY"
  
  # hard coding some vars for demo purposes only   
  cics_sys_def:    
    context:        "CICSTS63"         
    cmci_url:       "https://localhost:8154"         
    cmci_user:      "IBMUSER"
    cmci_password:  "{{ clave }}"
    insecure: True 

    # App Group:  
    csd_group:      "ESPSMTM"



  db2_sys_def:
    # Target Env specific settings     
    subsys:       "DBD1"
    sdsnload:     "DB2V13.SDSNLOAD"
    
    # Common app vars 
    user:         "IBMUSER"

    # Bind-Package building-block vars for deployType dbrm      
    #package_jobcard: "IBMUSERK JOB WD-PKGBIND,MSGLEVEL=(1,1),MSGCLASS=A"  
    package_jobcard:    "{{ jobcard }}"
    package:            "{{ pklist }}"
    qualifier:          "myQual"     
    package_action:     "REPLACE"   
    package_maxrc:      4     


    # Bind-Plan  building-block vars for deployType dbrmp
    plan_jobcard:       "{{ jobcard }}"
    plan:               "myplan"
    plan_pklist:        "*.{{ pklist }}.*"
    plan_action:        "REPLACE"     
    plan_maxrc:         4

  # Dataset allocations - These datasets are normally pre-allocated.  
  common_pds_load_spec:
      type:             LIBRARY
      primary_space:    10CYL
      secondary_space:  20CYL
      record_format:    U
      record_length:    0

  common_pds_binary_spec:
      type: LIBRARY
      primary_space:    10CYL
      secondary_space:  20CYL
      record_format:    FB
      record_length:    80



# -------------  
# This section maps an artifacts DeployType to a target Dataset in the host 
# Ref: https://www.ibm.com/docs/en/developer-for-zos/17.0.x?topic=translators-generic-environment-variables-ansible-python-building-blocks
types:
  - pattern:        .*\.LOAD$
    dataset:        "{{ hlq }}.LOAD"
    dataset_backup: "{{ hlq }}.BACK.LOAD"
    spec:           "{{ env.spec.common_pds_load_spec }}"
    is_load:        True
    force_lock:     True
    aliases:        True

  - pattern:        .*\.CICSLOAD$
    dataset:        "{{ hlq }}.LOADLIB"
    dataset_backup: "{{ hlq }}.BACK.LOADLIB"
    spec:           "{{ env.spec.common_pds_load_spec }}"
    is_load:        True
    force_lock:     True
    aliases:        True
    cics_systems:   
      - "{{ env.spec.cics_sys_def }}"

  - pattern:        .*\.MAPLOAD$
    dataset:        "{{ hlq }}.LOADLIB"
    dataset_backup: "{{ hlq }}.BACK.LOADLIB"
    spec:           "{{ env.spec.common_pds_load_spec }}"
    is_load:        True
    force_lock:     True
    aliases:        True
    cics_systems:   
      - "{{ env.spec.cics_sys_def }}"
  
  - pattern:        .*.DBRM$
    dataset:        "{{ hlq }}.DBRM"
    dataset_backup: "{{ hlq }}.BACK.DBRM"
    spec:           "{{ env.spec.common_pds_binary_spec }}"
    is_binary:      True
    force_lock:     True
    db2_systems:    
      - "{{ env.spec.db2_sys_def }}"
  
    
  - pattern:        .*.DBRMP$
    dataset:        "{{ hlq }}.DBRMP"
    dataset_backup: "{{ hlq }}.BACK.DBRMP"
    spec:           "{{ env.spec.common_pds_binary_spec }}"
    is_binary:      True
    force_lock:     True
    db2_systems:    
      - "{{ env.spec.db2_sys_def }}"
  